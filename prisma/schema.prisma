generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Category {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @map("created_at")
  events    Event[]

  @@map("categories")
}

model Event {
  id          Int        @id @default(autoincrement())
  name        String
  location    String
  dateEvent   DateTime   @map("date_event")
  description String
  categoryId  Int        @map("category_id")
  pembicaraId Int        @map("pembicara_id")
  createdAt   DateTime   @map("created_at")
  category    Category   @relation(fields: [categoryId], references: [id])
  pembicara   pembicaras @relation(fields: [pembicaraId], references: [id])

  @@index([categoryId], map: "events_category_id_fkey")
  @@index([pembicaraId], map: "events_pembicara_id_fkey")
  @@map("events")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  foto      String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("users")
}

model Role {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  @@map("roles")
}

model pembicaras {
  id         Int      @id @default(autoincrement())
  name       String
  role       String
  image      String
  created_at DateTime
  events     Event[]
}
